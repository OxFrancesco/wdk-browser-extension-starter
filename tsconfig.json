{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@": ["."],
      "@/*": ["./*"]
    },
    "moduleResolution": "Bundler",
    "skipLibCheck": true,
    "target": "ES2022"
  }
}
